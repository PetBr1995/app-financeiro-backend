FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-secret-key-with-at-least-32-characters
JWT_SECRET_KEY=change-this-jwt-secret-key-with-at-least-32-chars

# Local development (SQLite fallback) -> you can omit DATABASE_URL entirely.
# DATABASE_URL=sqlite:///app.db

# Production (Supabase/PostgreSQL example):
DATABASE_URL=postgresql://user:password@host:5432/dbname

JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
