FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-32-plus
JWT_SECRET_KEY=your-jwt-secret-key-32-plus

# Local development (SQLite fallback) -> you can omit DATABASE_URL entirely.
# DATABASE_URL=sqlite:///app.db

# Production (Supabase/PostgreSQL example):
DATABASE_URL=postgresql://user:password@host:5432/dbname

JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=true
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
# Em produção, mantenha false para não expor token na API.
PASSWORD_RESET_RETURN_TOKEN=false
PASSWORD_RESET_FRONTEND_URL=http://localhost:3000/reset-password?token={token}

# SMTP (envio real de email)
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USERNAME=seu-usuario-smtp
SMTP_PASSWORD=sua-senha-smtp
SMTP_FROM_EMAIL=no-reply@seu-dominio.com
SMTP_FROM_NAME=Financas API
SMTP_USE_TLS=true
SMTP_USE_SSL=false
